# OmniD3sk — Helpdesk & Productivity Orchestrator
# Copy this file to .env and fill in your values

# Google Cloud
PROJECT_ID=your-gcp-project-id
LOCATION=us-central1

# Model (Gemini Live for voice, Flash for ADK text chat)
MODEL=gemini-live-2.5-flash-native-audio
ADK_MODEL=gemini-2.5-flash
RESEARCH_MODEL=gemini-2.5-flash

# Enable ADK multi-agent orchestration
# Set to "true" to activate OmniAgent + OmniShield + researcher + threat_intel
ENABLE_ADK=false

# Session settings
SESSION_TIME_LIMIT=300

# Server
PORT=8080

# SQLite DB path (default: omniflow.db in project root)
OMNIFLOW_DB_PATH=omniflow.db

# ── MCP: Google Calendar Integration ────────────────────────────────────────
# Path to the service account JSON key file (already in project root)
GOOGLE_SERVICE_ACCOUNT_FILE=gcp-key.json

# Calendar ID to insert events into.
# Use "primary" for the service account's own calendar, OR the ID of a
# personal Google Calendar that has been shared with the service account email:
#   omnid3sk-local@lab2-491316.iam.gserviceaccount.com
# Find your Calendar ID in: Google Calendar → Settings → your calendar → "Integrate calendar"
CALENDAR_ID=primary

# ── MCP: Notion Integration ─────────────────────────────────────────────────
# Internal Integration Token from https://www.notion.so/my-integrations
# Format: secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_API_KEY=secret_your_notion_integration_token_here

# The ID of the Notion page to append reports to.
# Find it in the page URL: notion.so/<workspace>/<PAGE_ID>?v=...
# The ID is the 32-char hex string — with or without hyphens both work.
# Remember to share the page with your integration ("Share" → add integration).
NOTION_PAGE_ID=your_notion_page_id_here

