# OmniD3sk — Helpdesk & Productivity Orchestrator
# Copy this file to .env and fill in your values

# Google Cloud
PROJECT_ID=your-gcp-project-id
LOCATION=us-central1

# Model (Gemini Live for voice, Flash for ADK text chat)
MODEL=gemini-live-2.5-flash-native-audio
ADK_MODEL=gemini-2.5-flash
RESEARCH_MODEL=gemini-2.5-flash

# Enable ADK multi-agent orchestration
# Set to "true" to activate OmniAgent + OmniShield + researcher + threat_intel
ENABLE_ADK=false

# Session settings
SESSION_TIME_LIMIT=300

# Server
PORT=8080

# SQLite DB path (default: omniflow.db in project root)
OMNIFLOW_DB_PATH=omniflow.db
